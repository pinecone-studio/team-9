{
  "name": "team-9",
  "version": "1.0.0",
  "private": true,
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "npm run dev:dashboard",
    "dev:dashboard": "npm run dev --workspace @ebms/dashboard",
    "dev:service": "npm run dev --workspace @ebms/service",
    "lint": "npm run lint:dashboard",
    "lint:dashboard": "npm run lint --workspace @ebms/dashboard",
    "type-check": "npm run type-check:dashboard && npm run type-check:service",
    "type-check:dashboard": "npm run type-check --workspace @ebms/dashboard",
    "type-check:service": "npm run type-check --workspace @ebms/service",
    "test": "npm run test:service",
    "test:service": "npm run test --workspace @ebms/service",
    "build": "npm run build:dashboard && npm run build:service",
    "build:dashboard": "npm run build --workspace @ebms/dashboard",
    "build:service": "npm run build --workspace @ebms/service",
    "build:pages": "npm run build:pages --workspace @ebms/dashboard",
    "deploy:service": "npm run deploy --workspace @ebms/service"
  }
}