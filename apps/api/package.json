{
  "name": "@ebms/api",
  "version": "0.0.0",
  "private": true,
  "scripts": {
    "dev": "wrangler dev --remote --config wrangler.jsonc",
    "deploy": "wrangler deploy --config wrangler.jsonc",
    "start": "wrangler dev --config wrangler.jsonc",

    "test": "vitest run",

    "cf-typegen": "wrangler types --config wrangler.jsonc",
    "type-check": "tsc --noEmit",
    "build": "npm run type-check",

    "db:generate": "drizzle-kit generate",
    "db:migrate:local": "wrangler d1 migrations apply team9_pinequest --local",
    "db:migrate:remote": "wrangler d1 migrations apply team9_pinequest --remote",
    "db:studio": "drizzle-kit studio",
    "db:push": "drizzle-kit push"
  },
  "devDependencies": {
    "@cloudflare/vitest-pool-workers": "^0.12.4",
    "@cloudflare/workers-types": "^4.20260310.1",
    "drizzle-kit": "^0.30.0",
    "typescript": "^5.5.2",
    "vitest": "~3.2.0",
    "wrangler": "^3.101.0"
  },
  "dependencies": {
    "drizzle-orm": "^0.45.1",
    "hono": "^4.12.6"
  }
}