{
  "$schema": "./node_modules/nx/schemas/nx-schema.json",
  "affected": {
    "defaultBase": "main"
  },
  "workspaceLayout": {
    "appsDir": "apps",
    "libsDir": "packages"
  },
  "targetDefaults": {
    "build": {
      "dependsOn": ["^build"],
      "inputs": ["production", "^production"]
    },
    "type-check": {
      "inputs": ["default", "^production"]
    },
    "lint": {
      "inputs": ["default"]
    },
    "test": {
      "inputs": ["default", "^production"]
    }
  },
  "namedInputs": {
    "default": ["{projectRoot}/**/*"],
    "production": [
      "default",
      "!{projectRoot}/**/?(*.)+(spec|test).[jt]s?(x)?(.snap)",
      "!{projectRoot}/test/**/*",
      "!{projectRoot}/specs/**/*",
      "!{projectRoot}/tsconfig.spec.json",
      "!{projectRoot}/vitest.config.*"
    ]
  }
}
